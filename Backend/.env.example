# .env.example — copy to .env and fill in values
PORT=5000
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
JWT_SECRET="your_secret_key_here"
CORS_ORIGIN="https://your-app.vercel.app"

# Frontend URL (used in verification email links)
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL="https://your-app.vercel.app"

# Gmail (for email verification)
# 1. Enable 2-Step Verification on papyrusstudy@gmail.com
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Generate a password for "Mail" and paste it below (no spaces)
GMAIL_APP_PASSWORD="your_16_char_app_password"

# AI FastAPI Server (the AI team's Python server)
AI_API_URL="http://localhost:8000"
